# 5. Database Schema

## Users

CREATE TABLE users (

id UUID PRIMARY KEY,

name VARCHAR(100),

email VARCHAR(255) UNIQUE,

password_hash TEXT,

created_at TIMESTAMP

);

---

## AWS Accounts

CREATE TABLE aws_accounts (

id UUID PRIMARY KEY,

user_id UUID,

account_name VARCHAR(100),

access_key TEXT,

secret_key TEXT,

region VARCHAR(50),

created_at TIMESTAMP

);

---

## Scans

CREATE TABLE scans (

id UUID PRIMARY KEY,

account_id UUID,

scan_date TIMESTAMP,

total_savings NUMERIC,

created_at TIMESTAMP

);

---

## Findings

CREATE TABLE findings (

id UUID PRIMARY KEY,

scan_id UUID,

resource_type VARCHAR(50),

resource_id VARCHAR(255),

issue_type VARCHAR(100),

estimated_savings NUMERIC,

status VARCHAR(50)

);

---

## Jira Tickets

CREATE TABLE jira_tickets (

id UUID PRIMARY KEY,

finding_id UUID,

ticket_key VARCHAR(50),

status VARCHAR(50)

);

---

## Slack Notifications

CREATE TABLE slack_notifications (

id UUID PRIMARY KEY,

finding_id UUID,

channel_name VARCHAR(100),

sent_at TIMESTAMP

);

